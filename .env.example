# Core app
FLASK_CONFIG=config.DevConfig
# For deployment, switch this to: FLASK_CONFIG=config.ProdConfig
SECRET_KEY=replace_with_a_long_random_secret
PORT=5000

# Database
# For production, prefer Postgres and set DATABASE_URL.
# Example: DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=
AUTO_DB_BOOTSTRAP=1
# For production, run: flask --app wsgi db-upgrade
PROD_ALLOW_SQLITE=0

# Cookies
SESSION_COOKIE_SECURE=0
REMEMBER_COOKIE_SECURE=0

# Telegram bot
TELEGRAM_BOT_TOKEN=replace_with_your_new_bot_token
MANAGER_CHAT_IDS=2071265265
DEFAULT_FACTORY_ID=1
LOW_STOCK_THRESHOLD=5
DEFAULT_CASH_CURRENCY=UZS
PUBLIC_TELEGRAM_URL=https://t.me/your_bot_username

# Optional setup helpers
# SETUP_TOKEN=replace_me
# SETUP_ADMIN_USERNAME=admin
# SETUP_ADMIN_PASSWORD=replace_me
